3J9-y3m7Wko","P3J91~LtU7nZ","P3J93NWmbiuj","P3J95IiOjN3I","P3J96cC1OEwF","P3J96jZxboUx","P3J9T18fLeJT","P3J9TY4g_b.o","P3J9cV-1N7Os","P3J9kh2pQutu","P3J9sXYxu9nL","P3J9sZ3qw5G8","P3J9~n9uR9c9","Q3J96EvnnZXZ","Q3J96hB685Z5","Q3J9xX~HsVyD"],"lines":["Q3J92i~FqzaD","Q3J99.0HiuBT","Q3J9AFB8hqhl","Q3J9A_fLs-am","Q3J9B0se4gw~","Q3J9FvJHMRmd","Q3J9JlNxj2nO","Q3J9MQ38j6V4","Q3J9M_nx1_wi","Q3J9SNLgQrjl","Q3J9VLIIaeGI","Q3J9WDrnQ_ZM","Q3J9e8zy61yu","Q3J9fACPI.0a","Q3J9j-FouDY8","Q3J9r68hD7y~","Q3J9udbxMwsE","Q3J9z5HONUaZ"],"groups":[]}},{"id":"P3J96jZxboUx","class":"TerminatorBlockV2","textAreas":[{"label":"Text","text":"End"}],"customData":[],"linkedData":[{"collectionId":null,"data":[{"key":"SpreadsheetRowParentKey","value":"Primary_0"},{"key":"SpreadsheetColumnParentKey","value":"DEFAULT_EMPTY"}],"primaryKeyValue":"\"192d0e9f-2f5a-4032-9f03-59bbf1ea5891\""}]},{"id":"X3J9_SLAM600","class":"AutoGrowTextBlock","textAreas":[{"label":"Text","text":"Consulta y Gestión de NID\nOwner: Jefferson Guillermo Bejarano Granados\nLast Updated: 24 de jun. de 2026\nScope: Consulta de información de negocio por NID, validación contra los 9 procesos del orquestador, tratamiento de estados COMPLETED/IN_PROGRESS/REJECTED, opciones de solución y cierre del ticket."},{"label":"Placeholder","text":""}],"customData":[],"linkedData":[]},{"id":"P3J96cC1OEwF","class":"ProcessBlock","textAreas":[{"label":"Text","text":"Retornar: fecha y hora desde que está en proceso"}],"customData":[],"linkedData":[{"collectionId":null,"data":[{"key":"SpreadsheetRowParentKey","value":"Primary_1"},{"key":"SpreadsheetColumnParentKey","value":"DEFAULT_EMPTY"}],"primaryKeyValue":"\"192d0e9f-2f5a-4032-9f03-59bbf1ea5891\""}]},{"id":"X3J9zVyFPMsw","class":"AiResponseNoteBlock","textAreas":[{"label":"Title","text":"Chatbot/Ticketbot Orchestration Flow"},{"label":"Body","text":"Información del diagrama\nThis diagram shows the interaction between a Chatbot/Ticketbot, an Orchestrator, and a Ticketing system for handling requests with a NID (process identifier). It describes how the chatbot receives a request, queries the orchestrator for the NID status (COMPLETED, IN_PROGRESS, REJECTED), presents appropriate responses to the user, and offers options to retry, create tickets, or request manual review. The ticketing subsystem creates and maintains tickets until resolution and notifies closure.\n\nNID Status Handling and Ticketing SOP\n1. Begin at Start when a request with NID and specific query is received.\n2. Forward the request to the Orchestrator to review the NID across the 9 processes.\n\t2.1. Orchestrator evaluates and returns one of the statuses: COMPLETED, IN_PROGRESS, or REJECTED.\n3. If Orchestrator returns COMPLETED:\n\t3.1. Orchestrator returns execution date and approval comment.\n\t3.2. Present to user: \"NID COMPLETED\" with approval comment and execution date.\n\t3.3. End interaction.\n4. If Orchestrator returns IN_PROGRESS:\n\t4.1. Orchestrator returns start date/time (and current step if it's an approval task).\n\t4.2. Present to user: \"NID IN_PROGRESS\" with start date/time and, if applicable, current order/step in portal.\n\t4.3. End interaction.\n5. If Orchestrator returns REJECTED:\n\t5.1. Orchestrator returns rejection policy and rejection comment.\n\t5.2. Present to user: \"NID REJECTED\" showing rejection policy and comment.\n\t5.3. Offer the commercial options: Reintento / Ticket to area / Manual review.\n6. If user selects Reintento:\n\t6.1. Route back to Orchestrator to re-evaluate the processes (repeat steps 2–5 as needed).\n7. If user selects Ticket to area:\n\t7.1. Create a solution ticket assigned to the responsible area in the Ticketing system.\n\t7.2. Maintain the ticket updated until resolution and notify closure to the user.\n8. If user selects Manual review (only after Reintento and Ticket failed):\n\t8.1. Create a manual validation ticket in the Ticketing system.\n\t8.2. Maintain the ticket updated until resolution and notify closure to the user.\n9. After ticket resolution and closure, present End to the user and conclude the process."},{"label":"Attribution","text":"Generado por @Jefferson Guillermo Bejarano Granados el 24 de junio de 2026"}],"customData":[{"key":"ai-diagram-outline-block-selection","value":"[P3J9sZ3qw5G8, P3J9-y3m7Wko, P3J9sXYxu9nL, P3J91~LtU7nZ, P3J9T18fLeJT, P3J9~n9uR9c9, P3J93NWmbiuj, P3J96jZxboUx, P3J95IiOjN3I, P3J9kh2pQutu, P3J9TY4g_b.o, P3J96cC1OEwF, P3J9cV-1N7Os, Q3J96EvnnZXZ, Q3J9xX~HsVyD, Q3J96hB685Z5, Q3J9j-FouDY8, Q3J9z5HONUaZ, Q3J9MQ38j6V4, Q3J9fACPI.0a, ...]"},{"key":"ai-diagram-outline-block-document-id","value":"5a09e426-fde0-4c32-8607-e9cd362e5b7d"}],"linkedData":[]},{"id":"oLJ9UAdAXUw5","class":"SparkFrameBlock","textAreas":[{"label":"FrameTitle","text":"Consulta y Gestión de NID"}],"customData":[],"linkedData":[],"contains":{"shapes":["P3J9-y3m7Wko","P3J91~LtU7nZ","P3J93NWmbiuj","P3J95IiOjN3I","P3J96cC1OEwF","P3J96jZxboUx","P3J9T18fLeJT","P3J9TY4g_b.o","P3J9cV-1N7Os","P3J9kh2pQutu","P3J9sXYxu9nL","P3J9sZ3qw5G8","P3J9~n9uR9c9","Q3J93Bcn3Snp","Q3J96EvnnZXZ","Q3J96hB685Z5","Q3J9PfAU9RHa","Q3J9xX~HsVyD","X3J9_SLAM600","X3J9zVyFPMsw"],"lines":["Q3J92i~FqzaD","Q3J99.0HiuBT","Q3J9AFB8hqhl","Q3J9A_fLs-am","Q3J9B0se4gw~","Q3J9FvJHMRmd","Q3J9JlNxj2nO","Q3J9MQ38j6V4","Q3J9M_nx1_wi","Q3J9SNLgQrjl","Q3J9VLIIaeGI","Q3J9WDrnQ_ZM","Q3J9e8zy61yu","Q3J9fACPI.0a","Q3J9j-FouDY8","Q3J9r68hD7y~","Q3J9udbxMwsE","Q3J9z5HONUaZ"],"groups":[]}},{"id":"P3J93NWmbiuj","class":"DecisionBlock","textAreas":[{"label":"Text","text":"Ofrecer opción al comercial: Reintento / Ticket a área / Revisión manual"}],"customData":[],"linkedData":[{"collectionId":null,"data":[{"key":"SpreadsheetRowParentKey","value":"Primary_0"},{"key":"SpreadsheetColumnParentKey","value":"DEFAULT_EMPTY"}],"primaryKeyValue":"\"192d0e9f-2f5a-4032-9f03-59bbf1ea5891\""}]},{"id":"P3J9T18fLeJT","class":"ProcessBlock","textAreas":[{"label":"Text","text":"Presentar: NID IN_PROGRESS; mostrar fecha/hora de inicio; si es tarea de aprobación -> mo